{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "tester.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/recommend.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/feedback.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/recommend",
      "dest": "/api/recommend.js"
    },
    {
      "src": "/api/feedback",
      "dest": "/api/feedback.js"
    },
    {
      "src": "/tester",
      "dest": "/tester.html"
    },
    {
      "src": "/tester.html",
      "dest": "/tester.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
